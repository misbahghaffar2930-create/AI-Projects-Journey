class StyleZoneChatbot {
  constructor() {
    this.shopName = "StyleZone PK";
    this.location = "Lahore";
    this.whatsapp = "0300-1234567";
    this.deliveryDays = "3-5 working days";
    this.products = [
      { name: "Lawn Suit", price: 2500 },
      { name: "Linen Shirt", price: 1800 },
      { name: "Jeans", price: 3000 },
      { name: "Kurta", price: 1500 }
    ];
  }

  handleMessage(messageRaw) {
    const message = messageRaw.toLowerCase();

    // Check for product list inquiry
    if (/(available|dresses|products|kya hai|kya available)/.test(message)) {
      return "Hamare paas ye dresses hain:\n" +
        this.products.map(
          p => `- ${p.name} = ${p.price} Rs`
        ).join("\n");
    }

    // Check for price inquiry
    if (/price|kitne ka|rates|cost|qeemat/.test(message)) {
      let found = this.products.filter(p =>
        message.includes(p.name.toLowerCase())
      );
      if (found.length) {
        return found.map(p => `${p.name} ki price: ${p.price} Rs`).join("\n");
      } else {
        // Give price list if no product matched
        return "Prices ye hain:\n" +
          this.products.map(
            p => `${p.name}: ${p.price} Rs`
          ).join("\n");
      }
    }

    // Check for delivery inquiry
    if (/delivery|kitne din|kab tak|kitni der|shipping|pohanch/.test(message)) {
      return `Delivery ${this.deliveryDays} me ho jati hai!`;
    }

    // Check for location inquiry
    if (/location|kahan|address|shop/.test(message)) {
      return `Hamari shop "${this.shopName}" Lahore me hai.`;
    }

    // Check for contact/whatsapp inquiry
    if (/contact|whatsapp|number|phone/.test(message)) {
      return `WhatsApp: ${this.whatsapp}`;
    }

    // Restrict to only shop topic
    if (/hello|hi|salam|assalam|ap kaun|who are you/.test(message)) {
      return `Assalamualaikum, mai StyleZone PK ka chatbot hoon. Aap humare products, prices, delivery ya location ke baare mein pooch saktay hain!`;
    }

    return "Sirf shop (StyleZone PK) ke hawalay se sawal karein! Aap dresses, prices, delivery, ya location pooch saktay hain.";
  }
}

// Example Usage:
const chatbot = new StyleZoneChatbot();
console.log(chatbot.handleMessage("Lawn Suit ki price batao"));
console.log(chatbot.handleMessage("kon se dresses available hain?"));
console.log(chatbot.handleMessage("delivery kitne din me hoti hai?"));
console.log(chatbot.handleMessage("whatsapp number kya hai?"));



